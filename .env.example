# LLM providers
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=gpt-4.1

# LangSmith tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=tt
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Backward-compatible fallbacks
OPENAI_PROXY_API_KEY=
OPENAI_PROXY_BASE_URL=https://api.openai-proxy.org/v1
ANTHROPIC_PROXY_BASE_URL=https://api.openai-proxy.org/anthropic/v1
close=

# Optional internal OpenAI-compatible gateway
MT_OPENAI_API_KEY=
MT_OPENAI_BASE_URL=https://aigc.sankuai.com/v1/openai/native
mt=
tongyi=
zhipu=
deepseek=
DASHSCOPE_API_KEY=

# LangGraph persistence
LANGGRAPH_CHECKPOINTER=mysql
ALLOW_MEMORY_CHECKPOINTER_FALLBACK=false

# MySQL
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=tt
MYSQL_PASSWORD=tt_password
MYSQL_DATABASE=tt
MYSQL_ROOT_PASSWORD=root

# Redis
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Qdrant
QDRANT_HOST=host.docker.internal
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_HTTPS=false
